# VC Council Environment Variables
# Copy this file to .env and fill in your actual values.

# ========== LLM Provider ==========
# Choose one provider and set the matching API key.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMMA_MODEL=gemma-4-26b-a4b-it

# ========== Metorial MCP Platform ==========
# Get your API key from https://metorial.com
METORIAL_API_KEY=
METORIAL_BASE_URL=https://api.metorial.com/v1

# ========== Backend Configuration ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ========== Frontend Configuration ==========
# These are used by Vite.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
